# LiteLLM gateway. Required; the app does not call model providers directly.
LITE_LLM_KEY=replace-me
LITE_LLM_BASE_URL=http://localhost:4000

# Optional Langfuse tracing. Missing values disable tracing.
LANGFUSE_PUBLIC_KEY=replace-me
LANGFUSE_SECRET_KEY=replace-me
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Session secret. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string

# Initial admin account created on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-me

# Default model alias.
MODEL=claude-opus-4-8

# Scraper mode: auto | httpx | playwright.
SCRAPER_MODE=auto

# Data directory for SQLite and local runtime files.
DATA_DIR=/app/data

# Maximum number of images sent to the model.
MAX_IMAGES=12

# Public base URL used for share links.
PUBLIC_BASE_URL=https://example.com

# Optional Cloudflare Tunnel token if using the included compose setup.
CLOUDFLARE_TUNNEL_TOKEN=
